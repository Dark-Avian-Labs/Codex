{
  "name": "corpus",
  "version": "3.1.1",
  "private": true,
  "description": "Corpus - game collection tracker",
  "license": "GPL-3.0-or-later",
  "workspaces": [
    "packages/core",
    "packages/games/warframe",
    "packages/games/epic7"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "typecheck:server": "pnpm --filter @corpus/core --filter @corpus/game-warframe --filter @corpus/game-epic7 run --if-present build && tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm --filter @corpus/core --filter @corpus/game-warframe --filter @corpus/game-epic7 run --if-present build && pnpm run typecheck && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "validate": "node run-quality-checks.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check ."
  },
  "dependencies": {
    "@corpus/core": "workspace:*",
    "@corpus/game-epic7": "workspace:*",
    "@corpus/game-warframe": "workspace:*",
    "@dotenvx/dotenvx": "^1.59.1",
    "@fontsource-variable/inter": "^5.2.8",
    "better-sqlite3": "^12.8.0",
    "better-sqlite3-session-store": "^0.1.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3"
    ],
    "overrides": {
      "glob": "^13.0.6",
      "minimatch": "^10.2.4",
      "rimraf": "^6.1.3",
      "tar": "^7.5.11"
    }
  }
}
