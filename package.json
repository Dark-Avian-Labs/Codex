{
  "name": "corpus",
  "version": "3.1.2",
  "private": true,
  "description": "Corpus - game collection tracker",
  "license": "GPL-3.0-or-later",
  "workspaces": [
    "packages/core",
    "packages/games/warframe",
    "packages/games/epic7"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "typecheck:server": "pnpm --filter @corpus/core --filter @corpus/game-warframe --filter @corpus/game-epic7 run --if-present build && tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm --filter @corpus/core --filter @corpus/game-warframe --filter @corpus/game-epic7 run --if-present build && pnpm run typecheck && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "validate": "node run-quality-checks.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check ."
  },
  "dependencies": {
    "@corpus/core": "workspace:*",
    "@corpus/game-epic7": "workspace:*",
    "@corpus/game-warframe": "workspace:*",
    "@dotenvx/dotenvx": "catalog:",
    "@fontsource-variable/inter": "catalog:",
    "better-sqlite3": "catalog:",
    "better-sqlite3-session-store": "catalog:",
    "clsx": "catalog:",
    "cookie-parser": "catalog:",
    "csrf-sync": "catalog:",
    "express": "catalog:",
    "express-rate-limit": "catalog:",
    "express-session": "catalog:",
    "helmet": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/cookie-parser": "catalog:",
    "@types/express": "catalog:",
    "@types/express-session": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "globals": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3"
    ],
    "overrides": {
      "glob": "^13.0.6",
      "minimatch": "^10.2.4",
      "rimraf": "^6.1.3",
      "tar": "^7.5.11"
    }
  }
}
