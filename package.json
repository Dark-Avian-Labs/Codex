{
  "name": "corpus",
  "version": "3.1.1",
  "private": true,
  "description": "Corpus - game collection tracker",
  "license": "GPL-3.0-or-later",
  "workspaces": [
    "packages/core",
    "packages/games/warframe",
    "packages/games/epic7"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "typecheck:server": "npm run build --workspaces --if-present && tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "build": "npm run build --workspaces --if-present && npm run typecheck && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "validate": "node run-quality-checks.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check ."
  },
  "dependencies": {
    "@corpus/core": "3.1.0",
    "@corpus/game-epic7": "3.1.0",
    "@corpus/game-warframe": "3.1.0",
    "@dotenvx/dotenvx": "^1.55.1",
    "@fontsource-variable/inter": "^5.2.8",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.4",
    "rimraf": "^6.1.3",
    "tar": "^7.5.11"
  },
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=11.0.0"
  }
}
