{
  "name": "@codex/core",
  "version": "3.2.0",
  "description": "Codex core: auth, session, central DB, middleware",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation.js",
      "types": "./dist/validation.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check ."
  },
  "dependencies": {
    "@dotenvx/dotenvx": "catalog:",
    "better-sqlite3": "catalog:",
    "express": "catalog:",
    "express-session": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "catalog:",
    "@types/express": "catalog:",
    "@types/express-session": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.0.0"
  }
}
