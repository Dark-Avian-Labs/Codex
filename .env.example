# --------------------- Server Settings ----------------------
PORT=3001
HOST=127.0.0.1
NODE_ENV=production

# ------------------- Application Settings -------------------
APP_NAME=Codex
APP_ID=codex
BASE_PROTOCOL=https
BASE_DOMAIN=darkavianlabs.com
APP_SUBDOMAIN=codex
APP_PUBLIC_BASE_URL=https://codex.darkavianlabs.com
BASE_HOST=codex.darkavianlabs.com
GAME_HOSTS=codex.darkavianlabs.com=codex
# Comma-separated origins allowed for CSRF (Codex + other DAL apps on same domain)
ALLOWED_APP_ORIGINS=https://codex.darkavianlabs.com,https://armory.darkavianlabs.com

# ------------------- Session Settings -----------------------
# Used for CSRF tokens and Epic7 active account_id — not for login (Clerk handles auth)
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars
SESSION_COOKIE_NAME=darkavianlabs.codex.sid

# -------------------- Proxy Settings ------------------------
TRUST_PROXY=1
SECURE_COOKIES=1

# ------------------- Cookie Settings ------------------------
COOKIE_DOMAIN=.darkavianlabs.com

# ------------------- Clerk (required) -----------------------
# Dashboard → API Keys. Session token must include: "metadata": "{{user.public_metadata}}"
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ------------------- Databases ------------------------------
# Express-session store (CSRF, Epic7 active account). App-local — not shared with Armory.
SESSION_DB_PATH=/absolute/path/to/codex/data/session.db
# CENTRAL_DB_PATH is deprecated; use SESSION_DB_PATH (still accepted as a fallback).
WARFRAME_DB_PATH=./data/warframe.db
EPIC7_DB_PATH=./data/epic7.db
# Read-only Armory catalog for Warframe admin sync
ARMORY_DB_PATH=/path/to/armory/data/armory.db

# ------------------- Vite (client) --------------------------
VITE_BASE_PATH=/
VITE_APP_NAME=Codex
VITE_LEGAL_ENTITY_NAME="Dark Avian Labs"
VITE_LEGAL_PAGE_URL=https://darkavianlabs.com/legal/
VITE_SEARCH_PLACEHOLDER=Search
VITE_SHARED_THEME_COOKIE_DOMAIN=.darkavianlabs.com
