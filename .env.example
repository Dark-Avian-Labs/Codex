# --------------------- Server Settings ----------------------
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ------------------- Application Settings -------------------
APP_NAME=Codex
APP_ID=codex
BASE_PROTOCOL=https
BASE_DOMAIN=darkavianlabs.com
APP_SUBDOMAIN=codex
APP_PUBLIC_BASE_URL=https://codex.darkavianlabs.com
BASE_HOST=codex.darkavianlabs.com
GAME_HOSTS=codex.darkavianlabs.com=codex
ALLOWED_APP_ORIGINS=https://auth.darkavianlabs.com,https://codex.darkavianlabs.com

# ------------------- Session Settings -----------------------
SESSION_SECRET=change-this-to-a-long-random-string
SESSION_COOKIE_NAME=darkavianlabs.codex.sid
AUTH_FETCH_TIMEOUT_MS=5000

# -------------------- Proxy Settings ------------------------
TRUST_PROXY=1
SECURE_COOKIES=1

# ------------------- Cookie Settings ------------------------
COOKIE_DOMAIN=.darkavianlabs.com

# ------------------- Auth Service ---------------------------
AUTH_SERVICE_URL=https://auth.darkavianlabs.com

# ------------------- Databases ------------------------------
# Shared SQLite mounts should be absolute paths in deployment.
CENTRAL_DB_PATH=/mnt/dal/shared/auth/central.db
ARMORY_DB_PATH=/mnt/dal/shared/armory/armory.db
WARFRAME_DB_PATH=./data/warframe.db
EPIC7_DB_PATH=./data/epic7.db

# ------------------- Vite Settings --------------------------
VITE_BASE_PATH=/
VITE_APP_NAME=Codex
VITE_LEGAL_ENTITY_NAME="Dark Avian Labs"
VITE_LEGAL_PAGE_URL=/auth/legal
VITE_SEARCH_PLACEHOLDER="Search Codex..."
VITE_SHARED_THEME_COOKIE_DOMAIN=.darkavianlabs.com
