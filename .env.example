# --------------------- Server Settings ----------------------
PORT=3001
HOST=127.0.0.1
NODE_ENV=production

# ------------------- Application Settings -------------------
APP_NAME=Codex
APP_ID=codex
BASE_PROTOCOL=https
BASE_DOMAIN=darkavianlabs.com
APP_SUBDOMAIN=codex
APP_PUBLIC_BASE_URL=https://codex.darkavianlabs.com
# Comma-separated origins allowed for CSRF (Codex + other DAL apps on same domain)
ALLOWED_APP_ORIGINS=https://codex.darkavianlabs.com,https://armory.darkavianlabs.com

# ------------------- Session Settings -----------------------
# Used for CSRF tokens and per-game active account_id (Epic7, WoR) — not for login (Clerk handles auth)
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars
SESSION_COOKIE_NAME=darkavianlabs.codex.sid

# -------------------- Proxy Settings ------------------------
TRUST_PROXY=1
SECURE_COOKIES=1

# ------------------- Cookie Settings ------------------------
COOKIE_DOMAIN=.darkavianlabs.com

# ------------------- Clerk (required) -----------------------
# Dashboard → API Keys. Session token must include: "metadata": "{{user.public_metadata}}"
# ALLOWED_APP_ORIGINS should list every app origin that shares Clerk sessions (Codex + Armory).
# Server-side Clerk reads CLERK_PUBLISHABLE_KEY; VITE_ is used for the client bundle.
# Optional override if your Clerk Frontend API host differs from the default.
# CLERK_FAPI_URL=https://clerk.darkavianlabs.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ------------------- Databases ------------------------------
# Express-session store (CSRF, Epic7/WoR active account). App-local — not shared with Armory.
SESSION_DB_PATH=/absolute/path/to/codex/data/session.db
WARFRAME_DB_PATH=./data/warframe.db
EPIC7_DB_PATH=./data/epic7.db
WOR_DB_PATH=./data/wor.db
# Optional: imported portrait images for WoR catalog entries (default: ./data/wor-images)
# WOR_IMAGES_DIR=./data/wor-images
# Live Fastidious scrape (set WOR_IMPORT_OFFLINE=1 to use scripts/data/wor-import-cache only)
# WOR_IMPORT_LIVE=1
# WOR_IMPORT_OFFLINE=1
# WOR_FASTIDIOUS_USER_AGENT=CodexWoRImport/1.0 (your-contact@example.com)
# Required for Fandom wiki portrait downloads (Fastidious card images work without this)
# WIKI_USER_AGENT=CodexWoRImport/1.0 (your-contact@example.com)
# Read-only Armory catalog for Warframe admin sync
ARMORY_DB_PATH=/path/to/armory/data/armory.db

# ------------------- Vite (client) --------------------------
VITE_BASE_PATH=/
VITE_APP_NAME=Codex
VITE_LEGAL_ENTITY_NAME="Dark Avian Labs"
VITE_LEGAL_PAGE_URL=https://darkavianlabs.com/legal/
VITE_SEARCH_PLACEHOLDER=Search
VITE_SHARED_THEME_COOKIE_DOMAIN=.darkavianlabs.com
# Optional: id|Label|https://url pairs, comma-separated (defaults to Armory in prod)
# VITE_SIBLING_APPS=armory|Armory|https://armory.darkavianlabs.com
