# Plaintext env for CI when DOTENV_PRIVATE_KEY_DEVELOPMENT is unavailable
# (Dependabot PRs, forks). Used for `pnpm run build` only; Vitest does not load dotenv.

PORT=3001
HOST=127.0.0.1
NODE_ENV=test

APP_NAME=Corpus
APP_ID=corpus
BASE_PROTOCOL=https
BASE_DOMAIN=example.test
APP_SUBDOMAIN=corpus
APP_PUBLIC_BASE_URL=https://corpus.example.test
BASE_HOST=corpus.example.test
GAME_HOSTS=corpus.example.test=corpus
ALLOWED_APP_ORIGINS=https://auth.example.test,https://corpus.example.test

SESSION_SECRET=test-session-secret-32-characters-min
SESSION_COOKIE_NAME=darkavianlabs.corpus.sid
AUTH_FETCH_TIMEOUT_MS=5000

TRUST_PROXY=0
SECURE_COOKIES=0

COOKIE_DOMAIN=.example.test

AUTH_SERVICE_URL=https://auth.example.test

# DB paths: appended in testing.yml (must be absolute for @corpus/core config).

VITE_BASE_PATH=/
VITE_APP_NAME=Corpus
VITE_LEGAL_ENTITY_NAME=Dark Avian Labs
VITE_LEGAL_PAGE_URL=/auth/legal
VITE_SEARCH_PLACEHOLDER=Search Corpus...
VITE_SHARED_THEME_COOKIE_DOMAIN=.example.test
